# 6-Inferenza di voli indiretti
def identifica_tratta_senza_volo_diretto():
    citta = list(Citta.instances())
    for a in citta:
        for b in citta:
            for c in citta:
                if b in a.volo_diretto and c in b.volo_diretto:
                    if c not in a.volo_indiretto:
                        a.volo_indiretto.append(c)


# 7-Si desumono i voli assenti basandosi sul principio di CWA
tratte_assenti = set()

def principio_cwa_voli_assenti():
    citta = list(Citta.instances())
    for a in citta:
        for b in citta:
            if a != b and b not in a.volo_diretto and b not in a.volo_indiretto:
                tratte_assenti.add((a.name, b.name))

# 8-Definizione delle funzioni per verificare i voli
def verifica_volo_diretto(a, b):
    return b in a.volo_diretto

def verifica_volo_indiretto(a, b):
    return b in a.volo_indiretto

def verifica_volo_assente(a, b):
    return (a.name, b.name) in tratte_assenti


# 9- Esecuzione funzioni
identifica_tratta_senza_volo_diretto()
principio_cwa_voli_assenti()

# 10- Funzione verifica Voli
def funzione_di_verifica():
  coppie = [  (pechino, bucarest), (pechino, crotone), (trieste, crotone), (bucarest, pechino),
        (aosta, pechino), (mondello, bucarest), (aosta, miami), (copenaghen, crotone) ]
  for a, b in coppie:
        print(f"\nDa {a.name} a {b.name}:")
        print(" Volo Diretto Disponibile:", verifica_volo_diretto(a, b))
        print(" Volo Indiretto Disponibile:", verifica_volo_indiretto(a, b))
        print(" Nessuna possibile tratta trovata:", verifica_volo_assente(a, b))

funzione_di_verifica()

