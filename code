from owlready2 import *


# 2-Creazione ontologia
onto = get_ontology("http://esempio.org/rete_trasporti.owl")

with onto:
    #3-Definizione delle classi
    class Citta(Thing): pass
    class Volo(Thing): pass

    class LuogoPartenza(ObjectProperty):
        domain = [Volo]
        range = [Citta]

    class LuogoArrivo(ObjectProperty):
        domain = [Volo]
        range = [Citta]

    class volo_diretto(ObjectProperty):
        domain = [Citta]
        range = [Citta]

    class volo_indiretto(ObjectProperty):
        domain = [Citta]
        range = [Citta]

# 4-Creazione delle città
pechino = Citta("Pechino")
trieste = Citta("Trieste")
crotone = Citta("Crotone")
bucarest = Citta("Bucarest")
mondello = Citta("Mondello")
miami = Citta("Miami")
aosta = Citta("Aosta")
copenaghen = Citta("Copenaghen")

# 5- Creazione voli diretti
def istituisci_nuova_tratta_diretta(da_citta, a_citta):
    volo = Volo(f"volo_{da_citta.name}_{a_citta.name}")
    volo.LuogoPartenza = [da_citta]
    volo.LuogoArrivo = [a_citta]
    da_citta.volo_diretto.append(a_citta)

istituisci_nuova_tratta_diretta(pechino, trieste)
